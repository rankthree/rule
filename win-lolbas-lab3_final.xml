    <mitre><id>T1218</id><id>T1059</id></mitre>
  </rule>

  <rule id="210105" level="13">
    <if_sid>61605</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\addinutil\.exe$</field>
    <description>High AddinUtil.exe: outbound connection to $(win.eventdata.destinationIp):$(win.eventdata.destinationPort)</description>
    <mitre><id>T1218</id></mitre>
  </rule>

  <rule id="210106" level="10">
