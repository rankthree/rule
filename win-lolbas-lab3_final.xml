
<group name="windows,sysmon,attack_lab,lolbas">

  <rule id="210100" level="0">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\addinutil\.exe$</field>
    <description>Base AddinUtil.exe via Sysmon on $(win.system.computer)</description>
    <options>no_full_log</options>
  </rule>

  <rule id="210101" level="0">
    <if_sid>60109</if_sid>
    <field name="win.eventdata.newProcessName" type="pcre2">(?i)\\addinutil\.exe$</field>
    <description>Base AddinUtil.exe via Security Log on $(win.system.computer)</description>
    <options>no_full_log</options>
  </rule>

  <rule id="210102" level="12">
    <if_sid>210100,210101</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)[-\/](?:addinroot|pipelineroot)\s*:\s*["']?[A-Za-z]:\\(?:users|public|temp|tmp|downloads|desktop|appdata|programdata)(?:\\|["']|$)</field>
    <description>Suspicious AddinUtil.exe: sensitive path argument on $(win.system.computer)</description>
    <mitre><id>T1218</id></mitre>
  </rule>

  <rule id="210103" level="15">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\addinutil\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(?:bash|bitsadmin|calc|certutil|cmd|cmstp|cscript|installutil|mshta|msiexec|powershell|pwsh|regsvr32|rundll32|wscript)\.exe$</field>
    <description>Critical AddinUtil.exe: child process [$(win.eventdata.image)] spawned on $(win.system.computer)</description>
    <mitre><id>T1218</id><id>T1059</id></mitre>
  </rule>

  <rule id="210104" level="15">
    <if_sid>60109</if_sid>
    <field name="win.eventdata.parentProcessName" type="pcre2">(?i)\\addinutil\.exe$</field>
    <field name="win.eventdata.newProcessName" type="pcre2">(?i)\\(?:bash|bitsadmin|calc|certutil|cmd|cmstp|cscript|installutil|mshta|msiexec|powershell|pwsh|regsvr32|rundll32|wscript)\.exe$</field>
