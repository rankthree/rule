    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)ms-appinstaller:\/\/(?:\?source=)?https?:</field>
    <description>Suspicious AppInstaller.exe: ms-appinstaller URI in PowerShell ScriptBlock on $(win.system.computer)</description>
    <mitre><id>T1105</id></mitre>
  </rule>

